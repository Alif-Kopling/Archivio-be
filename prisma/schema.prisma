generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String
  role     String   // admin / staff

  documents Document[]
}
model Document {
  id        Int      @id @default(autoincrement())
  title     String
  sender    String?
  documentDate DateTime?
  filePath  String
  type      String   // masuk / keluar / sertifikat
  status    String   @default("draft") // draft / final
  createdAt DateTime @default(now())

  createdBy Int
  user      User     @relation(fields: [createdBy], references: [id])

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
